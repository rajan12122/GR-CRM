# Server configuration
PORT=5000

# Security secrets
# Generate random base64 key: openssl rand -base64 48
JWT_SECRET="your-jwt-secret-key-goes-here"
JWT_EXPIRY="8h"

# Geolocation AES-256-GCM key (64 hex characters / 256-bit key)
# Generate random hex key: openssl rand -hex 32
DB_ENCRYPTION_KEY="your-64-character-hexadecimal-key-goes-here"

# Google Sheets Integration
GOOGLE_SERVICE_ACCOUNT_EMAIL="sync-service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ..."
GOOGLE_SPREADSHEET_ID="your-google-spreadsheet-id-goes-here"
GOOGLE_SHEETS_SYNC_ACTIVE="true"
